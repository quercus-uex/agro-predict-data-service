# === Base de datos ===
SQLALCHEMY_DATABASE_URL=mysql+pymysql://user:password@localhost:3306/agro_predict
# Usada solo por la configuración de testing (por defecto usa sqlite en memoria)
TEST_DATABASE_URL=sqlite:///:memory:

# === Servicios externos de datos ===
SIAR_SERVICE_DATA_URL=http://localhost:5001/data
SIAR_SERVICE_INFO_URL=http://localhost:5001/info
AEMET_SERVICE_CURRENT_URL=http://localhost:5002/current
AEMET_SERVICE_FUTURE_URL=http://localhost:5002/future
ITACYL_SERVICE_BASE_URL=http://localhost:5003
DTAGRO_SERVICE_BASE_URL=http://localhost:5004
DTAGRO_API_TOKEN=change-me

# === RabbitMQ ===
RABBITMQ_CONNECTION=amqp://guest:guest@localhost:5672/%2F
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
QUEUE_IN_NAME=raw_data
QUEUE_OUT_NAME=processed_data

# === Redis (Celery broker/backend) ===
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_USER=default
REDIS_PASS=

