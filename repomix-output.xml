    monkeypatch.setitem(
        historico_service_module._TIPO_CONFIG,
        TipoHistorico.HORA,
        (fake_dao_fn, "_build_historico_hora", "valores_horarios"),
    )

    result_hora = HistoricService._leer_datos_ready(
        tipo=TipoHistorico.HORA,
        estacion_id=15,
        provincia_id="CC",
